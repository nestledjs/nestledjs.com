{
  "name": "Coder (from plan)",
  "context": "nestled",
  "description": "Fires the task description as a claude --remote prompt piped to FlightDesk. No local session — TaskOS runs the command directly.",
  "command": "cd ~/IdeaProjects/nestledjs.com && flightdesk register --project 443ad943-56e7-4aab-a480-17f3d1c3bd12 --title '{title}' --prompt '{description}'",
  "output_rules": [
    {
      "pattern": "Task ID: ([a-f0-9-]{36})",
      "action": "add_link",
      "url": "https://flightdesk.dev/app/tasks/{1}"
    }
  ],
  "project": "nestledjs.com"
}
