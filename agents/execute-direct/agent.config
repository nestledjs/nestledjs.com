{
  "name": "Coder (from task)",
  "context": "nestled",
  "description": "Compiles task title, description, links, and attachments into a spec and fires it directly at claude --remote. No local intermediary — TaskOS runs the command itself.",
  "command": "cd ~/IdeaProjects/nestledjs.com && flightdesk register --project 443ad943-56e7-4aab-a480-17f3d1c3bd12 --title '{title}' --prompt '{description}'",
  "project": "nestledjs.com"
}
